<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng ký</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap"
          rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-gradient-to-br from-purple-100 via-white to-indigo-100 min-h-screen flex items-center justify-center p-4">

    <div class="w-full max-w-md bg-white/90 backdrop-blur-lg rounded-3xl shadow-2xl p-10 border border-white">

        <div class="text-center mb-8">

            <div class="w-20 h-20 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fa-solid fa-user-plus text-4xl text-purple-600"></i>
            </div>

            <h1 class="text-3xl font-extrabold text-purple-900">
                TẠO TÀI KHOẢN
            </h1>

            <p class="text-slate-500 mt-2">
                Đăng ký để sử dụng Contact Book
            </p>
        </div>

        <form action="/register" method="POST" class="space-y-5">

            <!-- Username -->
            <div>
                <label class="block text-sm font-semibold text-slate-600 mb-2">
                    Username
                </label>

                <div class="relative">

                    <input type="text"
                           name="username"
                           required
                           placeholder="Nhập username"
                           class="w-full p-4 pl-12 rounded-2xl border border-slate-200 focus:ring-2 focus:ring-purple-400 outline-none">

                    <i class="fa-solid fa-user absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>

                </div>
            </div>

            <!-- Email -->
            <div>
                <label class="block text-sm font-semibold text-slate-600 mb-2">
                    Gmail
                </label>

                <div class="relative">

                    <input type="email"
                           name="email"
                           required
                           placeholder="example@gmail.com"
                           class="w-full p-4 pl-12 rounded-2xl border border-slate-200 focus:ring-2 focus:ring-purple-400 outline-none">

                    <i class="fa-solid fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>

                </div>
            </div>

            <!-- Password -->
            <div>
                <label class="block text-sm font-semibold text-slate-600 mb-2">
                    Password
                </label>

                <div class="relative">

                    <input type="password"
                           name="password"
                           required
                           placeholder="Nhập mật khẩu"
                           class="w-full p-4 pl-12 rounded-2xl border border-slate-200 focus:ring-2 focus:ring-purple-400 outline-none">

                    <i class="fa-solid fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>

                </div>
            </div>

            <!-- Confirm Password -->
            <div>
                <label class="block text-sm font-semibold text-slate-600 mb-2">
                    Nhập lại Password
                </label>

                <div class="relative">

                    <input type="password"
                           name="confirmPassword"
                           required
                           placeholder="Nhập lại mật khẩu"
                           class="w-full p-4 pl-12 rounded-2xl border border-slate-200 focus:ring-2 focus:ring-purple-400 outline-none">

                    <i class="fa-solid fa-shield-halved absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>

                </div>
            </div>

            <button type="submit"
                    class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-4 rounded-2xl shadow-lg transition-all">
                <i class="fa-solid fa-user-plus mr-2"></i>
                Đăng ký
            </button>

        </form>

        <div class="text-center mt-6 text-slate-500">

            Đã có tài khoản?

            <a href="/login"
               class="text-purple-600 font-bold hover:underline">
                Đăng nhập
            </a>

        </div>

    </div>

</body>
</html>
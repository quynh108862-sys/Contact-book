<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sổ Địa Chỉ</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap"
          rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
        }
    </style>
</head>

<body class="bg-gradient-to-br from-slate-100 to-indigo-50 min-h-screen flex flex-col">

<main class="flex-grow max-w-4xl w-full mx-auto py-12 px-4">

    <!-- Top -->
    <div class="flex justify-between items-center mb-6">

        <div class="bg-white px-5 py-3 rounded-2xl shadow text-slate-700 font-semibold flex items-center gap-2">
            <i class="fa-solid fa-user text-indigo-500"></i>

            Xin chào,

            <span class="text-indigo-600">
                <%= typeof user !== 'undefined' && user ? user.username : "Guest" %>
            </span>
        </div>

        <a href="/logout"
           class="bg-red-500 hover:bg-red-600 text-white px-5 py-3 rounded-2xl shadow transition-all">

            <i class="fa-solid fa-right-from-bracket mr-2"></i>
            Logout

        </a>

    </div>

    <!-- Title -->
    <div class="text-center mb-10">

        <h1 class="text-4xl font-extrabold text-indigo-900 tracking-tight mb-2">
            <i class="fa-solid fa-address-book text-indigo-600 mr-3"></i>
            CONTACT BOOK
        </h1>

        <p class="text-slate-500 text-lg">
            Quản lý danh bạ thông minh và nhanh chóng
        </p>

    </div>

    <!-- Search -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">

        <form action="/" method="GET" class="md:col-span-2 relative">

            <input type="text"
                   name="search"
                   value="<%= query %>"
                   placeholder="Tìm tên hoặc số điện thoại..."
                   class="w-full pl-11 pr-4 py-3.5 border-none rounded-2xl shadow-sm focus:ring-2 focus:ring-indigo-500 glass-card transition-all outline-none">

            <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                <i class="fa-solid fa-magnifying-glass"></i>
            </div>

        </form>

        <button onclick="document.getElementById('add-form-container').classList.toggle('hidden')"
                class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3.5 rounded-2xl shadow-lg shadow-indigo-200 transition-all flex items-center justify-center border-none">

            <i class="fa-solid fa-plus-circle mr-2 text-lg"></i>
            Thêm Mới

        </button>

    </div>

    <!-- Add Form -->
    <div id="add-form-container" class="hidden mb-10">

        <div class="glass-card p-8 rounded-3xl shadow-xl border border-white">

            <div class="flex items-center mb-6 text-indigo-800">

                <div class="w-1 bg-indigo-600 h-6 mr-3 rounded-full"></div>

                <h2 class="text-xl font-bold">
                    Thông tin liên hệ mới
                </h2>

            </div>

            <form action="/add" method="POST"
                  class="grid grid-cols-1 md:grid-cols-3 gap-6">

                <div class="space-y-2">

                    <label class="text-sm font-semibold text-slate-600 ml-1">
                        Họ và Tên
                    </label>

                    <input type="text"
                           name="name"
                           required
                           placeholder="Nguyễn Như Quỳnh"
                           class="w-full p-3.5 bg-slate-50 border border-slate-200 rounded-xl focus:border-indigo-400 outline-none">

                </div>

                <div class="space-y-2">

                    <label class="text-sm font-semibold text-slate-600 ml-1">
                        Số điện thoại
                    </label>

                    <input type="text"
                           name="phone"
                           required
                           placeholder="09xx xxx xxx"
                           class="w-full p-3.5 bg-slate-50 border border-slate-200 rounded-xl focus:border-indigo-400 outline-none">

                </div>

                <div class="space-y-2">

                    <label class="text-sm font-semibold text-slate-600 ml-1">
                        Email
                    </label>

                    <input type="email"
                           name="email"
                           placeholder="email@gmail.com"
                           class="w-full p-3.5 bg-slate-50 border border-slate-200 rounded-xl focus:border-indigo-400 outline-none">

                </div>

                <div class="md:col-span-3 text-right">

                    <button type="submit"
                            class="bg-emerald-500 hover:bg-emerald-600 text-white font-bold px-10 py-3.5 rounded-xl shadow-md transition-all border-none">

                        Xác nhận Lưu

                    </button>

                </div>

            </form>

        </div>

    </div>

    <!-- Table -->
    <div class="glass-card rounded-3xl shadow-xl overflow-hidden border border-white">

        <table class="w-full text-left border-collapse">

            <thead>

            <tr class="bg-indigo-900/5 text-indigo-900 uppercase text-xs tracking-widest font-bold">

                <th class="p-5">Người liên hệ</th>

                <th class="p-5">Thông tin liên lạc</th>

                <th class="p-5 text-center">Thao tác</th>

            </tr>

            </thead>

            <tbody class="divide-y divide-slate-100">

            <% if (contacts && contacts.length > 0) { %>

                <% contacts.forEach(contact => { %>

                    <tr class="hover:bg-indigo-50/50 transition-colors group">

                        <td class="p-5">

                            <div class="flex items-center">

                                <div class="w-10 h-10 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center font-bold mr-4 group-hover:bg-indigo-600 group-hover:text-white transition-all">

                                    <%= contact.name ? contact.name.charAt(0).toUpperCase() : '?' %>

                                </div>

                                <div>

                                    <div class="font-bold text-slate-800 text-lg">
                                        <%= contact.name %>
                                    </div>

                                    <div class="text-xs text-slate-400 italic">
                                        ID: <%= contact._id.toString().slice(-6) %>
                                    </div>

                                </div>

                            </div>

                            <div class="font-bold text-slate-800 text-lg mt-2">

                                <a href="/edit/<%= contact._id %>"
                                   class="hover:text-indigo-600">

                                    <%= contact.name %>

                                    <i class="fa-solid fa-pen-to-square text-xs opacity-50"></i>

                                </a>

                            </div>

                        </td>

                        <td class="p-5">

                            <div class="text-indigo-600 font-semibold mb-1">

                                <i class="fa-solid fa-phone mr-2 text-xs opacity-70"></i>

                                <%= contact.phone %>

                            </div>

                            <div class="text-slate-500 text-sm italic">

                                <i class="fa-solid fa-envelope mr-2 text-xs opacity-70"></i>

                                <%= contact.email || 'Chưa cập nhật' %>

                            </div>

                        </td>

                        <td class="p-5 text-center">

                            <a href="/delete/<%= contact._id %>"
                               onclick="return confirm('Xóa liên hệ này?')"
                               class="text-slate-300 hover:text-red-500 transition-colors text-xl">

                                <i class="fa-solid fa-trash-can"></i>

                            </a>

                        </td>

                    </tr>

                <% }) %>

            <% } else { %>

                <tr>

                    <td colspan="3"
                        class="p-20 text-center text-slate-400 italic font-medium">

                        <i class="fa-solid fa-inbox text-5xl mb-4 block opacity-20"></i>

                        Trống trơn... Hãy thêm liên hệ đầu tiên!

                    </td>

                </tr>

            <% } %>

            </tbody>

        </table>

    </div>

    <!-- Pagination -->
    <div class="flex justify-center items-center gap-3 mt-10">

        <% if(currentPage > 1){ %>

            <a href="/?page=<%= currentPage - 1 %>&search=<%= query %>"
               class="w-10 h-10 flex items-center justify-center rounded-full bg-white shadow hover:bg-indigo-100">

                <i class="fa-solid fa-angle-left"></i>

            </a>

        <% } %>

        <% for(let i = 1; i <= totalPages; i++){ %>

            <a href="/?page=<%= i %>&search=<%= query %>"
               class="w-10 h-10 flex items-center justify-center rounded-full shadow font-semibold transition-all
               <%= currentPage === i
                    ? 'bg-indigo-600 text-white scale-110'
                    : 'bg-white text-slate-700 hover:bg-indigo-100'
               %>">

                <%= i %>

            </a>

        <% } %>

        <% if(currentPage < totalPages){ %>

            <a href="/?page=<%= currentPage + 1 %>&search=<%= query %>"
               class="w-10 h-10 flex items-center justify-center rounded-full bg-white shadow hover:bg-indigo-100">

                <i class="fa-solid fa-angle-right"></i>

            </a>

        <% } %>

    </div>

</main>

<footer class="py-6 text-center text-slate-400 text-xs border-t border-slate-200/50">

    <p>© 2026 Smart Contact System • Node.js & MongoDB</p>

</footer>

</body>
</html>